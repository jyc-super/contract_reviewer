# Supabase (DB·Auth)
# 로컬: http://localhost:54321 (npx supabase start 후 .env.local 참고)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# 향후 브라우저/Auth 세션 사용 시 필요. 현재 앱은 Admin 클라이언트만 사용.
# NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Gemini (조항 분석·embedding)
# 메인 UI에서 입력해 암호화 저장할 때 아래 ENCRYPTION_KEY가 필요합니다. (Supabase 없어도 로컬 파일에 저장 가능)
GEMINI_API_KEY=your-gemini-api-key

# API 키 암호화 저장용 — 배포(production) 환경에서는 32자 이상 필수. 로컬 개발 시에는 없어도 됨(자동으로 개발용 키 사용). 32자 이상 또는 64자 hex.
# ENCRYPTION_KEY=your-32-byte-or-longer-secret-key

# Docling (선택, PDF/DOCX 레이아웃 추출). 끝에 슬래시 없이 설정.
# DOCLING_SERVICE_URL=http://localhost:5001
