{
  "parts": [
    {
      "key": "contract_agreement",
      "isAnalysisTarget": true,
      "patterns": [
        "^\\s*(?:part\\s+[ivx\\d]+\\s*[-:]\\s*)?contract\\s+agreement\\b",
        "^\\s*this\\s+contract\\s+agreement\\b",
        "^\\s*epc\\s+contract\\s+agreement\\b",
        "^\\s*agreement\\s*$",
        "^\\s*계\\s*약\\s*서\\s*$",
        "^\\s*(?:공사|용역|물품|도급|하도급)?\\s*계약서\\s*$"
      ]
    },
    {
      "key": "general_conditions",
      "isAnalysisTarget": true,
      "patterns": [
        "^\\s*(?:part\\s+[ivx\\d]+\\s*[-:]\\s*)?general\\s+conditions(?:\\s+of\\s+contract)?\\b",
        "^\\s*gc\\b.*\\bgeneral\\s+conditions\\b",
        "^\\s*book\\s*(?:ii|2)\\b.*\\bgeneral\\s+conditions\\b",
        "^\\s*section\\s*[a-z]\\b.*\\bgeneral\\s+conditions\\b",
        "^\\s*general\\s+provisions\\s*$",
        "^\\s*\\d+\\s+general\\s+provisions\\b",
        "^\\s*일\\s*반\\s*(?:사항|조건|조항)\\s*$",
        "^\\s*공\\s*통\\s*(?:사항|조건|조항)\\s*$"
      ]
    },
    {
      "key": "particular_conditions",
      "isAnalysisTarget": true,
      "patterns": [
        "^\\s*(?:part\\s+[ivx\\d]+\\s*[-:]\\s*)?particular\\s+conditions(?:\\s+of\\s+contract)?\\b",
        "^\\s*special\\s+conditions(?:\\s+of\\s+contract)?\\b",
        "^\\s*pc\\b.*\\bparticular\\s+conditions\\b",
        "^\\s*book\\s*(?:iii|3)\\b.*\\bparticular\\s+conditions\\b",
        "^\\s*section\\s*[b-z]\\b.*\\bparticular\\s+conditions\\b",
        "^\\s*특\\s*수\\s*(?:사항|조건|조항)\\s*$",
        "^\\s*특\\s*별\\s*(?:사항|조건|조항)\\s*$"
      ]
    },
    {
      "key": "conditions_of_contract",
      "isAnalysisTarget": true,
      "patterns": [
        "^\\s*(?:part\\s+[ivx\\d]+\\s*[-:]\\s*)?conditions\\s+of\\s+(?:contract|subcontract)\\b",
        "^\\s*\\d+\\s+conditions\\s+of\\s+(?:contract|subcontract)\\b",
        "^\\s*fidic\\s+conditions\\s+of\\s+(?:contract|subcontract)\\b",
        "^\\s*conditions\\s*$",
        "^\\s*계약\\s*(?:일반)?\\s*조건\\s*$"
      ]
    },
    {
      "key": "technical_specifications",
      "isAnalysisTarget": false,
      "patterns": [
        "^\\s*(?:part\\s+[ivx\\d]+\\s*[-:]\\s*)?(?:technical\\s+)?specifications?\\b",
        "^\\s*\\d+\\s+(?:technical\\s+)?specifications?\\b",
        "^\\s*employer'?s\\s+requirements\\b",
        "^\\s*owner'?s\\s+requirements\\b"
      ]
    },
    {
      "key": "commercial_terms",
      "isAnalysisTarget": true,
      "patterns": [
        "^\\s*commercial\\s+terms\\b",
        "^\\s*price\\s+and\\s+payment\\b"
      ]
    },
    {
      "key": "appendices",
      "isAnalysisTarget": false,
      "patterns": [
        "^\\s*schedules?\\b",
        "^\\s*schedule\\s+[a-z0-9]+\\b",
        "^\\s*appendi(?:x|ces)\\b",
        "^\\s*exhibits?\\b",
        "^\\s*annex(?:es)?\\b"
      ]
    },
    {
      "key": "definitions",
      "isAnalysisTarget": true,
      "patterns": [
        "^\\s*(?:\\d+(?:\\.\\d+)*)\\s*definitions\\b",
        "^\\s*\\d+\\s+definitions\\b",
        "^\\s*definitions\\b"
      ]
    },
    {
      "key": "toc",
      "isAnalysisTarget": false,
      "patterns": [
        "^\\s*table\\s+of\\s+contents\\b",
        "^\\s*contents\\b",
        "^\\s*index\\b"
      ]
    },
    {
      "key": "cover_page",
      "isAnalysisTarget": false,
      "patterns": [
        "^\\s*cover\\s+(?:page|sheet)\\b",
        "^\\s*title\\s+page\\b"
      ]
    },
    {
      "key": "drawing_list",
      "isAnalysisTarget": false,
      "patterns": [
        "^\\s*(?:list\\s+of\\s+)?drawings?\\b",
        "^\\s*drawing\\s+(?:register|schedule|list)\\b"
      ]
    },
    {
      "key": "form_of_tender",
      "isAnalysisTarget": false,
      "patterns": [
        "^\\s*form\\s+of\\s+tender\\b",
        "^\\s*tender\\s+form\\b"
      ]
    },
    {
      "key": "letter_of_acceptance",
      "isAnalysisTarget": true,
      "patterns": [
        "^\\s*letter\\s+of\\s+(?:acceptance|award|intent)\\b"
      ]
    },
    {
      "key": "bill_of_quantities",
      "isAnalysisTarget": false,
      "patterns": [
        "^\\s*bill\\s+of\\s+quantities\\b",
        "^\\s*(?:schedule\\s+of\\s+)?rates?\\s+and\\s+prices?\\b"
      ]
    }
  ]
}
